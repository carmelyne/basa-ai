# Deployment Configuration Template
# Copy this file to .deploy.env and update with your credentials.
# Do NOT commit .deploy.env to version control.

DEPLOY_METHOD=ssh
DEPLOY_HOST=your-host-here
DEPLOY_USER=your-user-here
DEPLOY_PATH=/home/your-user/your-path
DEPLOY_PORT=7822

# Asset Pipeline Configuration
KLEIN_IMAGES_DIR=/path/to/local/images
CWEBP_PATH=/usr/local/bin/cwebp
